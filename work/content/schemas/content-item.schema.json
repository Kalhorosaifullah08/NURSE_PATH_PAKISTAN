{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nursepath.pk/schemas/content-item.schema.json",
  "title": "NursePath Pakistan content item",
  "type": "object",
  "required": ["id", "curriculumVersion", "semester", "courseId", "learningOutcomeIds", "contentType", "body", "difficulty", "sourceIds", "model", "promptVersion", "risk", "reviewState", "revision", "createdAt"],
  "properties": {
    "id": {"type": "string", "minLength": 4},
    "curriculumVersion": {"type": "string"},
    "semester": {"type": "integer", "minimum": 1, "maximum": 8},
    "courseId": {"type": "string"},
    "learningOutcomeIds": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "contentType": {"enum": ["lesson", "mcq", "flashcard", "written_prompt", "assessment"]},
    "body": {"type": "object"},
    "difficulty": {"enum": ["foundation", "intermediate", "advanced"]},
    "sourceIds": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "model": {"type": "string"},
    "promptVersion": {"type": "string"},
    "automatedReview": {"type": "object"},
    "risk": {"enum": ["general", "academic", "clinical", "pharmacology", "calculation", "emergency", "patient_safety"]},
    "reviewState": {"enum": ["draft", "automated_review", "owner_review", "approved", "rejected", "published"]},
    "revision": {"type": "integer", "minimum": 1},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
