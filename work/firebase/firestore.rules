rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner() { return signedIn() && request.auth.token.owner == true; }

    match /publishedPackages/{packageId} {
      allow read: if true;
      allow write: if false;
    }

    match /students/{studentId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == studentId;
      match /{document=**} {
        allow read, write: if signedIn() && request.auth.uid == studentId;
      }
    }

    match /content/{contentId} {
      allow read, write: if owner();
    }

    match /reviewAssignments/{assignmentId} {
      allow read, write: if owner();
    }

    match /entitlements/{entitlementId} {
      allow read: if signedIn() && resource.data.studentId == request.auth.uid;
      allow write: if owner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
